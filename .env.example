# Google ADK API Configuration
# Get your API key from: https://aistudio.google.com/apikey
# or use Vertex AI with Google Cloud

# Option 1: Use Gemini via Google AI Studio
# GOOGLE_API_KEY=your-api-key-here

# Option 2: Use Vertex AI (Google Cloud)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Option 3: Use OpenAI compatible API (OpenRouter, etc.)
OPENAI_API_KEY=sk-or-v1-your-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ============================================================================
# LLM Model Configuration (统一模型配置)
# ============================================================================
# 所有模型使用 LiteLLM 格式，通过 OpenRouter 可以访问多种模型

# 默认模型（所有 agent 默认使用此模型）
ADK_DEFAULT_MODEL=openai/qwen/qwen3.6-plus

# 协调器模型（通常需要更强的推理能力，可选）
# ADK_COORDINATOR_MODEL=openai/qwen/qwen-2.5-72b-instruct

# 执行者模型（处理特定领域任务，可选）
# ADK_EXECUTOR_MODEL=openai/qwen/qwen-2-7b-instruct:free

# ReAct Agent 模型（需要推理能力，可选）
# ADK_REACT_MODEL=openai/qwen/qwen-2.5-7b-instruct

# Thinking Agent 模型（需要支持 thinking 的模型，如 Gemini 2.5+）
# ADK_THINKING_MODEL=gemini-2.5-flash

# Optional: Logging level
LOG_LEVEL=INFO